# Paired t-test for CSpR vs CSpNR
t_test_results <- list()
for (ph in c("EXT", "EXT-RE", "REN")) {
# Filter data for the phase
ph_data <- master_data_cleaned %>% filter(Phase == ph)
# For each connection
for (conn in significant_conn_ids) {
# Extract values for the two conditions
r_vals <- ph_data %>% filter(CS_Type == "CSpR") %>% pull(!!sym(conn))
nr_vals <- ph_data %>% filter(CS_Type == "CSpNR") %>% pull(!!sym(conn))
# Run the t-test (ensuring same length/ordered by ID)
t_res <- t.test(r_vals, nr_vals, paired = TRUE)
# Store results
t_test_results[[paste(ph, conn)]] <- data.frame(
Variable = conn,
Phase = ph,
t_stat = t_res$statistic,
df = t_res$parameter,
p_val = t_res$p.value,
mean_diff = t_res$estimate
)
}
}
t_summary <- bind_rows(t_test_results)
t_summary
